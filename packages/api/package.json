{
  "name": "@apifyn/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "pnpm --filter @apifyn/database generate && tsc",
    "start": "node dist/index.js",
    "start:ts": "ts-node src/index.ts",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:watch": "nodemon --exec ts-node src/index.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "test": "jest"
  },
  "dependencies": {
    "@apifyn/database": "workspace:*",
    "@prisma/client": "^5.8.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.75.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.8.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^7.0.0",
    "ioredis": "^5.10.1",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.5",
    "openai": "^6.34.0",
    "prisma": "^5.8.1",
    "razorpay": "^2.9.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.15",
    "@types/nodemailer": "^8.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
