NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

DATABASE_URL=postgresql://user:password@localhost:5432/apifyn
GOOGLE_CLIENT_ID=
JWT_SECRET=change-me-to-a-random-64-char-string
REDIS_URL=redis://localhost:6379
ALLOWED_ORIGINS=http://localhost:3000
BASE_URL=http://localhost:5000

# GitHub OAuth (for user GitHub integration)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# Slack OAuth
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Discord (no OAuth needed — users paste their own webhook URL in the builder)

# Notion OAuth — https://developers.notion.com
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:5000/api/integrations/notion/callback

# SMTP (for sending emails via Gmail) — use a Gmail App Password
# Generate at: https://myaccount.google.com/apppasswords
SMTP_USER=
SMTP_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Google APIs (Sheets, Calendar) — same Google Cloud project, enable each API
GOOGLE_API_CLIENT_ID=
GOOGLE_API_CLIENT_SECRET=
GOOGLE_API_REDIRECT_URI=http://localhost:5000/api/integrations/google/callback

# Razorpay — https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Typeform (no server-side key — users configure webhook URL in Typeform dashboard)

# OpenAI — for AI workflow generation (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Server-only secret used to AES-256-GCM encrypt user & per-workflow OpenAI API keys at rest.
# Must be exactly 64 hex characters (32 bytes). Generate once: openssl rand -hex 32
# Never commit a real value; set in production via your host’s secret manager.
SECRETS_ENCRYPTION_KEY=

# MSG91 — for WhatsApp messages (https://msg91.com/whatsapp)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_INTEGRATED_NUMBER=

# Razorpay Webhook — for payment triggers (https://razorpay.com/docs/webhooks)
RAZORPAY_WEBHOOK_SECRET=
